  "currentInteractionLoop": [
    "open index.html",
    "src/boot.js imports src/start.js",
    "src/start.js creates createOrchardGame, createWorldCanvas, and createHtmlInterfaceRenderer",
    "src/game.js installs resource-ledger, pressure-field, orchard-world, construction-runtime, roster-runtime, inventory-runtime, generated interface domains, active-session, and interface-composition kits",
    "requestAnimationFrame calls engine.tick(1 / 60)",
    "tickable domains update pressure and active-session state",
    "engine.snapshot aggregates every domain snapshot",
    "world-canvas renders trees, apples, pests, and player from snapshots",
    "html-interface-renderer renders active-session HUD or a generic interface screen",
    "click[data-action] routes to interface-composition.activate",
    "click[data-command] routes directly to active-session commands",
    "window.GameHost exposes engine, getState, and tick",
    "exchange screen currently only routes back"
  ],
  "targetInteractionLoop": [
    "active-session routes Market to exchange",
    "exchange-domain-kit exposes sell-apples, buy-basic-tool, buy-row-supply, and back",
    "exchange action creates a MarketCommandEnvelope",
    "MarketSourceSnapshot captures resources, inventory, prices, capacity, frame, and elapsed",
    "market-preflight returns accepted/rejected with stable reason",
    "accepted commands mutate resource-ledger/inventory-runtime and append transaction records",
    "rejected commands append command result records without mutating values",
    "interface-composition returns nested command result and stores lastResult",
    "market-result-projection exposes renderer-ready Market state",
    "exchange-renderer-authority renders prices, capacity, latest result, disabled reason, and recent transactions",
    "gamehost-market-diagnostics exposes dispatch, snapshots, journals, diagnostics, and runSmoke",
    "market-smoke-contract verifies replay parity without DOM timing assumptions"
